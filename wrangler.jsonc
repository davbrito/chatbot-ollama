{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "chatbot-ollama",
  "compatibility_date": "2026-03-10",
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"],
  },
  "main": "./worker/index.ts",
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
  },
}
